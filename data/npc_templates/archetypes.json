        "social_influence":  {"min": 0.30, "max": 0.60},
        "conformity":        {"min": 0.40, "max": 0.60},
        "novelty_seeking":   {"min": 0.20, "max": 0.45}
      },
      "count_range": [8, 10],
      "preferred_connections": ["pragmatist", "follower", "gatekeeper", "budget_conscious"]
    },
    {
      "id": "skeptic",
      "label": "Skeptic",
      "decision_style": "Risk-first. Assumes new things are worse until proven otherwise. Looks for flaws.",
      "adoption_path": "awareness → what could go wrong? → resists → needs trusted peer endorsement → slow adoption → strong retention",
      "typical_objections": [
        "This sounds too good to be true",
        "What happens to my data?",
        "Who is behind this?",
        "I've seen this kind of thing fail before"
