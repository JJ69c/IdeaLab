  "archetypes": [
    {
      "id": "analytical_skeptic",
      "label": "Analytical Skeptic",
      "decision_style": "Risk-first. Evaluates evidence, looks for flaws, assumes claims are exaggerated. Needs credible proof and trusted endorsement before engaging.",
      "adoption_path": "awareness -> what could go wrong? -> resists -> needs credible evidence or trusted peer endorsement -> slow adoption -> very strong retention",
      "typical_objections": [
        "This sounds too good to be true",
        "Where is the data to back these claims?",
        "Who is behind this and what's their track record?",
        "I've seen similar things fail before"
      ],
      "influence_susceptibility": "low_marketing, high_trusted_peer, high_evidence",
      "spread_likelihood": "low_volume_high_impact",
      "traits": {
        "openness":          {"min": 0.20, "max": 0.40},
        "skepticism":        {"min": 0.75, "max": 0.95},
        "tech_savviness":    {"min": 0.50, "max": 0.80},
        "price_sensitivity": {"min": 0.35, "max": 0.60},
        "social_influence":  {"min": 0.55, "max": 0.80},
        "conformity":        {"min": 0.10, "max": 0.30},
        "novelty_seeking":   {"min": 0.05, "max": 0.25}
      },
      "evaluation_weights": {
        "utility_clarity": 0.25,
        "differentiation": 0.15,
        "identity_fit": 0.05,
        "novelty": -0.05,
        "trust_barrier": -0.25,
