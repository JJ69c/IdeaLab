{
  "archetypes": [
    {
      "id": "enthusiast",
      "label": "Enthusiast",
      "decision_style": "Emotion-first, explores before evaluating. Gets excited by vision and novelty. Decides fast.",
      "adoption_path": "awareness → immediate interest → tries it → tells everyone → may cool off",
      "typical_objections": [
        "What happens after the hype?",
        "Is this actually different from what already exists?",
        "Will this still be around in a year?"
      ],
      "influence_susceptibility": "high_novelty, moderate_social, low_price",
      "spread_likelihood": "high",
      "traits": {
        "openness":          {"min": 0.75, "max": 0.95},
        "skepticism":        {"min": 0.10, "max": 0.30},
        "tech_savviness":    {"min": 0.60, "max": 0.90},
        "price_sensitivity": {"min": 0.15, "max": 0.35},
        "social_influence":  {"min": 0.65, "max": 0.90},
        "conformity":        {"min": 0.20, "max": 0.40},
        "novelty_seeking":   {"min": 0.80, "max": 0.95}
      },
      "count_range": [4, 5],
      "preferred_connections": ["enthusiast", "gatekeeper", "pragmatist"]
    },
    {
      "id": "pragmatist",
      "label": "Pragmatist",
      "decision_style": "Utility-first. Evaluates cost/benefit. Needs clear problem-to-solution mapping.",
      "adoption_path": "awareness → what problem does this solve? → evaluates alternatives → cautious trial → adopts if measurable benefit",
      "typical_objections": [
        "How is this better than what I use now?",
        "What's the switching cost?",
        "Show me the numbers",
        "Does this integrate with my current workflow?"
      ],
      "influence_susceptibility": "high_utility, moderate_peer, low_novelty",
      "spread_likelihood": "moderate",
      "traits": {
        "openness":          {"min": 0.40, "max": 0.60},
