ANTHROPIC_API_KEY=your-api-key-here

# PostgreSQL (production) — requires a running PostgreSQL instance
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/idealab

# SQLite (dev fallback) — no external dependencies, just uncomment:
# DATABASE_URL=sqlite+aiosqlite:///./idealab.db

# JWT auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-hex-string
